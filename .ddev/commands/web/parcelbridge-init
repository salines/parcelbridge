#!/usr/bin/env bash
set -euo pipefail

cd /var/www/html

if [ ! -d vendor ]; then
  composer install
elif [ composer.lock -nt vendor/autoload.php ]; then
  composer install
else
  composer install --no-interaction --no-progress
fi

bin/cake migrations migrate

user_count="$(mysql -h db -u db -pdb db -Nse 'SELECT COUNT(*) FROM users' 2>/dev/null || echo 0)"
if [ "${user_count}" = "0" ]; then
  bin/cake seeds run InitSeed --force
else
  echo "ParcelBridge seed skipped: users table already contains ${user_count} record(s)."
fi
