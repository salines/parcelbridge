{
    "name": "salines/parcelbridge",
    "description": "CakePHP 5 application for package forwarding and shipment workflows",
    "license": "MIT",
    "funding": [
        {
            "type": "custom",
            "url": "https://www.paypal.me/paradzikn"
        }
    ],
    "type": "project",
    "homepage": "https://github.com/salines/parcelbridge",
    "require": {
        "php": ">=8.3",
        "cakephp/authentication": "^4.1",
        "cakephp/authorization": "^3.5",
        "cakephp/cakephp": "5.3.*",
        "cakephp/migrations": "^5.0",
        "cakephp/plugin-installer": "^2.0",
        "dompdf/dompdf": "^3.0",
        "friendsofcake/cakepdf": "^5.1",
        "friendsofcake/cakephp-csvview": "^5.0",
        "friendsofcake/search": "^7.8",
        "josegonzalez/cakephp-upload": "^8.1",
        "mobiledetect/mobiledetectlib": "^4.8.03"
    },
    "require-dev": {
        "cakedc/cakephp-phpstan": "4.2.0",
        "cakephp/bake": "^3.6",
        "cakephp/cakephp-codesniffer": "^5.3",
        "cakephp/debug_kit": "^5.2",
        "dereuromark/cakephp-ide-helper": "^2.17",
        "josegonzalez/dotenv": "^4.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5.3 || ^12.1.3 || ^13.0",
        "swagger-api/swagger-ui": "^5.32"
    },
    "suggest": {
        "cakephp/repl": "Console tools for a REPL interface for CakePHP applications.",
        "markstory/asset_compress": "An asset compression plugin which provides file concatenation and a flexible filter system for preprocessing and minification."
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Test\\": "tests/",
            "Cake\\Test\\": "vendor/cakephp/cakephp/tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "cakephp/plugin-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform-check": true,
        "sort-packages": true
    },
    "scripts": {
        "post-install-cmd": "App\\Console\\Installer::postInstall",
        "post-create-project-cmd": "App\\Console\\Installer::postInstall",
        "check": [
            "@test",
            "@stan",
            "@cs-check"
        ],
        "cs-check": "phpcs --colors -p",
        "cs-fix": "phpcbf --colors -p",
        "stan": "phpstan analyse --memory-limit=512M",
        "test": "phpunit --colors=always"
    }
}
